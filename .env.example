PORT=3000
NODE_ENV=development
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres
SUPABASE_DB_SSL=true
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECT_TIMEOUT_MS=10000
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_ISSUER=nodeauth-api
JWT_AUDIENCE=nodeauth-client
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=12
TRUST_PROXY=false
CORS_ORIGIN=http://localhost:3000
